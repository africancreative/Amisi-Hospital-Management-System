{
  "name": "@amisimedos/web",
  "version": "4.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "pnpm --filter @amisimedos/db build && pnpm --filter @amisimedos/billing build && pnpm --filter @amisimedos/ui build && pnpm --filter @amisimedos/sync build && pnpm --filter @amisimedos/chat build && node scripts/vercel-engine-hack.js && next build --webpack",
    "copy-prisma": "node scripts/copy-prisma.js",
    "start": "node server.mjs",
    "lint": "eslint"
  },
  "dependencies": {
    "@amisimedos/auth": "workspace:^",
    "@amisimedos/billing": "workspace:^",
    "@amisimedos/chat": "workspace:^",
    "@amisimedos/constants": "workspace:*",
    "@amisimedos/db": "workspace:^",
    "@amisimedos/sync": "workspace:^",
    "@amisimedos/ui": "workspace:^",
    "@paypal/paypal-server-sdk": "1.0.0",
    "@paypal/react-paypal-js": "^9.1.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.99.0",
    "@trpc/client": "^11.16.0",
    "@trpc/next": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "body-parser": "^2.2.2",
    "bonjour-service": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "framer-motion": "^12.4.7",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^2.15.1",
    "resend": "^6.10.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^9.0.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "postinstall": "pnpm --filter @amisimedos/db build && pnpm --filter @amisimedos/ui build && pnpm --filter @amisimedos/sync build && pnpm --filter @amisimedos/chat build && pnpm --filter @amisimedos/db db:generate"
}

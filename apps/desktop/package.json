{
  "name": "@amisimedos/desktop",
  "version": "1.0.0",
  "description": "AmisiMedOS Desktop - Digital Healthcare Platform",
  "author": {
    "name": "Amisi Genuine",
    "email": "support@amisigenuine.com"
  },
  "homepage": "https://amisigenuine.com",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "PORT=5000 ts-node-dev --respawn src/index.ts",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5000/api/health && electron .\"",
    "build": "tsc",
    "postbuild": "cp -r src/assets dist/ 2>/dev/null || :",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@amisimedos/auth": "workspace:*",
    "@amisimedos/db": "workspace:*",
    "@amisimedos/sync": "workspace:*",
    "bonjour-service": "^1.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-is-dev": "^3.0.1",
    "electron-store": "^8.2.0",
    "express": "^4.19.2",
    "os": "^0.1.2"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "@types/bonjour": "^3.5.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/node": "^20.12.7",
    "helmet": "^7.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}

// Tauri Configuration for Cross-Platform Installables
// src-tauri/tauri.conf.json

{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:3000",
    "distDir": "../out"
  },
  "package": {
    "productName": "AmisiMedOS Node",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "http": {
        "all": true,
        "request": true,
        "scope": ["https://api.amisimedos.ai/*"]
      },
      "shell": {
        "all": false,
        "execute": true,
        "scope": [{ "name": "postgres", "cmd": "postgres" }]
      },
      "fs": {
        "all": true,
        "scope": ["$APPCONFIG/*", "$APPDATA/*"]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all", 
      "identifier": "com.amisimedos.node",
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/256x256.png"]
    },
    "window": {
      "title": "AmisiMedOS Local Node",
      "width": 1280,
      "height": 800
    }
  }
}

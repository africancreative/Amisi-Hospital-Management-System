{
    "name": "@amisimedos/db",
    "version": "1.0.0",
    "description": "Shared Prisma Database Library for Amisi Hospital SaaS",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js",
        "./client": "./dist/client.js"
    },
    "scripts": {
        "build": "pnpm generate && tsc",
        "generate": "prisma generate --schema=./prisma/control.prisma && prisma generate --schema=./prisma/tenant.prisma",
        "db:generate": "pnpm generate",
        "db:generate:control": "prisma generate --schema=./prisma/control.prisma",
        "db:generate:tenant": "prisma generate --schema=./prisma/tenant.prisma",
        "db:push:control": "prisma db push --schema=./prisma/control.prisma",
        "db:push:tenant": "prisma db push --schema=./prisma/tenant.prisma",
        "db:studio:control": "prisma studio --schema=./prisma/control.prisma",
        "db:studio:tenant": "prisma studio --schema=./prisma/tenant.prisma",
        "db:seed:demo": "npx tsx src/seed-demo.ts",
        "db:seed:comprehensive": "npx tsx src/seed-comprehensive.ts",
        "db:seed:all": "npx tsx src/seed-all-tenants.ts"
    },
    "dependencies": {
        "@prisma/client": "^5.13.0",
        "buffer": "^6.0.3",
        "dotenv": "^16.4.5",
        "drizzle-orm": "^0.30.0",
        "node-vault": "^0.12.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/node": "^20.12.7",
        "@types/node-vault": "^0.9.13",
        "drizzle-kit": "^0.21.0",
        "prisma": "^5.13.0",
        "typescript": "^5.4.5"
    }
}

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/control-client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("NEON_DATABASE_URL")
  directUrl = env("NEON_DIRECT_URL")
}

model Tenant {
  id                     String                 @id @default(uuid())
  name                   String
  slug                   String                 @unique
  dbUrl                  String                 @map("db_url")
  encryptionKeyReference String                 @map("encryption_key_reference")
  tier                   DeploymentTier         @default(CLINIC)
  region                 String
  status                 TenantStatus           @default(active)
  suspensionReason       String?                @map("suspension_reason")
  suspendedAt            DateTime?              @map("suspended_at")
  address                String?
  logoUrl                String?                @map("logo_url")
  primaryColor           String?                @default("#2563EB") @map("primary_color")
  secondaryColor         String?                @default("#0F172A") @map("secondary_color")
  trialEndsAt            DateTime?              @map("trial_ends_at")
  enabledModules         Json                   @default("{}") @map("enabled_modules")
  queueConfig            Json?                  @map("queue_config")
  billingConfig          Json?                  @map("billing_config")
  staffRoles             Json?                  @map("staff_roles")
  publicKeySpki          String?                @map("public_key_spki")
  sharedSecret           String?                @map("shared_secret")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  complianceIsolation    Json                   @default("{\"byok_enabled\": false, \"data_residency\": \"\", \"isolation_policy\": \"logical\"}") @map("compliance_isolation")
  facilityType           FacilityType           @default(CLINIC) @map("facility_type")
  moduleConfig           Json                   @default("{}") @map("module_config")
  subscriptionQuotas     Json                   @default("{\"seat_limit\": 5, \"storage_mb\": 5000}") @map("subscription_quotas")
  workflowCustomization  Json                   @default("{\"queue_logic\": {\"routing_rules\": [], \"triage_levels\": [\"Critical\", \"Urgent\", \"Routine\"]}, \"staff_roles\": {}, \"billing_rules\": {\"currency\": \"USD\", \"tax_rate\": 0, \"payment_methods\": [\"CASH\", \"CARD\", \"MPESA\"]}}") @map("workflow_customization")
  featureFlagOverrides   FeatureFlagOverride[]
  subscriptions          Subscription[]
  payments               SystemPayment[]
  configAuditLogs        TenantConfigAuditLog[]
  tenantFeatureFlags     TenantFeatureFlag[]
  entitlements           TenantModule[]
  usages                 TenantUsage[]

  @@map("tenants")
}

model Module {
  id           String         @id @default(uuid())
  name         String
  code         String         @unique
  description  String?
  basePrice    Decimal        @default(0) @map("base_price") @db.Decimal(10, 2)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  dependencies Json           @default("[]") @map("dependencies")
  events       Json           @default("[]") @map("events")
  permissions  Json           @default("[]") @map("permissions")
  featureFlags FeatureFlag[]
  tenants      TenantModule[]

  @@map("modules")
}

model TenantModule {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  moduleId   String    @map("module_id")
  isEnabled  Boolean   @default(true) @map("is_enabled")
  validUntil DateTime? @map("valid_until")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  module     Module    @relation(fields: [moduleId], references: [id])
  tenant     Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, moduleId])
  @@map("tenant_modules")
}

model SystemAdmin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("system_admins")
}

model GlobalSettings {
  id                  String   @id @default("singleton")
  platformName        String   @default("AmisiMedOS") @map("platform_name")
  platformLogoUrl     String?  @map("platform_logo_url")
  platformSlogan      String?  @map("platform_slogan")
  heroTitle           String?  @map("hero_title")
  heroSubtitle        String?  @map("hero_subtitle")
  heroCTA             String?  @map("hero_cta")
  heroImageUrl        String?  @map("hero_image_url")
  showHero            Boolean  @default(true) @map("show_hero")
  showFeatures        Boolean  @default(true) @map("show_features")
  feature1Title       String?  @map("feature1_title")
  feature1Desc        String?  @map("feature1_desc")
  feature1Icon        String?  @map("feature1_icon")
  feature2Title       String?  @map("feature2_title")
  feature2Desc        String?  @map("feature2_desc")
  feature2Icon        String?  @map("feature2_icon")
  feature3Title       String?  @map("feature3_title")
  feature3Desc        String?  @map("feature3_desc")
  feature3Icon        String?  @map("feature3_icon")
  paypalClientId      String?  @map("paypal_client_id")
  paypalClientSecret  String?  @map("paypal_client_secret")
  paypalEnv           String   @default("sandbox") @map("paypal_env")
  mpesaConsumerKey    String?  @map("mpesa_consumer_key")
  mpesaConsumerSecret String?  @map("mpesa_consumer_secret")
  mpesaPasskey        String?  @map("mpesa_passkey")
  mpesaShortcode      String?  @map("mpesa_shortcode")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("global_settings")
}

model SystemPayment {
  id            String   @id @default(uuid())
  tenantId      String?  @map("tenant_id")
  amount        Decimal  @db.Decimal(10, 2)
  currency      String   @default("USD")
  method        String
  status        String
  reference     String   @unique
  customerEmail String   @map("customer_email")
  customerName  String   @map("customer_name")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])

  @@map("system_payments")
}

model Plan {
  id            String         @id @default(uuid())
  name          String
  code          String         @unique
  description   String?
  price         Decimal        @db.Decimal(10, 2)
  currency      String         @default("USD")
  billingCycle  BillingCycle   @default(MONTHLY) @map("billing_cycle")
  features      Json           @default("[]")
  maxPatients   Int            @default(100) @map("max_patients")
  maxUsers      Int            @default(5) @map("max_users")
  maxBeds       Int            @default(10) @map("max_beds")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id          String        @id @default(uuid())
  tenantId    String        @map("tenant_id")
  planId      String        @map("plan_id")
  status      String        @default("ACTIVE")
  startDate   DateTime      @default(now()) @map("start_date")
  endDate     DateTime?     @map("end_date")
  signedToken String?       @map("signed_token")
  autoRenew   Boolean       @default(true) @map("auto_renew")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  plan        Plan          @relation(fields: [planId], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  usages      TenantUsage[]

  @@map("subscriptions")
}

model PatientIndex {
  biometricHash String   @id @map("biometric_hash")
  biometricType String   @map("biometric_type")
  tenantId      String   @map("tenant_id")
  patientId     String   @map("patient_id")
  description   String?
  timestamp     DateTime @default(now())
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("patient_index")
}

model TenantUsage {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  subscriptionId String       @map("subscription_id")
  date           DateTime     @db.Date
  activeUsers    Int          @default(0) @map("active_users")
  activePatients Int          @default(0) @map("active_patients")
  storageUsedMb  Decimal      @default(0) @map("storage_used_mb") @db.Decimal(10, 2)
  apiCallsCount  Int          @default(0) @map("api_calls_count")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  tenant         Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date])
  @@index([subscriptionId])
  @@map("tenant_usage")
}

model SyncNode {
  id            String   @id @default(uuid())
  nodeName      String   @map("node_name")
  nodeType      String   @default("EDGE")
  lastHeartbeat DateTime @default(now()) @map("last_heartbeat")
  version       String
  status        String   @default("HEALTHY")
  config        Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("sync_nodes")
}

model FeatureFlag {
  id           String                @id @default(uuid())
  flagId       String                @unique @map("flag_id")
  scope        String                @default("global") @map("scope")
  moduleId     String?               @map("module_id")
  defaultValue Boolean               @default(false) @map("default_value")
  description  String?
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  overrides    FeatureFlagOverride[]
  module       Module?               @relation(fields: [moduleId], references: [id])
  tenantFlags  TenantFeatureFlag[]

  @@map("feature_flags")
}

model FeatureFlagOverride {
  id        String      @id @default(uuid())
  flagId    String      @map("flag_id")
  tenantId  String?     @map("tenant_id")
  enabled   Boolean     @default(true)
  createdAt DateTime    @default(now()) @map("created_at")
  flag      FeatureFlag @relation(fields: [flagId], references: [id])
  tenant    Tenant?     @relation(fields: [tenantId], references: [id])

  @@unique([flagId, tenantId])
  @@map("feature_flag_overrides")
}

model TenantConfigAuditLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  actorId   String   @map("actor_id")
  actorName String   @map("actor_name")
  actorRole String   @map("actor_role")
  action    String
  field     String?
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  timestamp DateTime @default(now()) @map("timestamp")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, timestamp])
  @@map("tenant_config_audit_logs")
}

model TenantFeatureFlag {
  id        String      @id @default(uuid())
  tenantId  String      @map("tenant_id")
  flagId    String      @map("flag_id")
  enabled   Boolean     @default(false)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  flag      FeatureFlag @relation(fields: [flagId], references: [id])
  tenant    Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, flagId])
  @@map("tenant_feature_flags")
}

enum TenantStatus {
  active
  suspended
  terminated
}

enum DeploymentTier {
  CLINIC
  HOSPITAL
  NETWORK
  GENERAL
  RESEARCH
  PHARMACY
  LAB
  SPECIALIST
}

enum FacilityType {
  CLINIC
  PHARMACY
  LAB
  SPECIALIST
  HOSPITAL
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

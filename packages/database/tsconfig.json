{
    "compilerOptions": {
        "target": "es2022",
        "module": "commonjs",
        "declaration": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./src"
    },
    "include": [
        "src/index.ts",
        "src/config.ts",
        "src/tenant-routing.ts",
        "src/provision.ts"
    ]
}
{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build",
                "@amisi/database#db:generate"
            ],
            "inputs": [
                "$TURBO_DEFAULT$",
                ".env*"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "dist/**"
            ],
            "env": [
                "DATABASE_URL",
                "JWT_SECRET",
                "CLOUD_SYNC_URL",
                "NODE_ENV"
            ]
        },
        "build-mobile": {
            "cache": false,
            "inputs": [
                "apps/mobile/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
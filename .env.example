# Shared defaults (do not put secrets here)

# Databases
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/CONTROL_DB
LOCAL_EDGE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/TENANT_DB

# Auth
JWT_SECRET=change_me

# Sync
CLOUD_SYNC_URL=https://api.example.com/api/sync
SYNC_SHARED_SECRET=change_me
SYNC_INTERVAL_MS=30000

# Mode
NODE_ENV=development
CLOUD_MODE=true
